# ===========================================
# Node.js (Fastify) サーバー用 .env テンプレート
# コピーして .env を作成し、値を設定してください。
# ===========================================

# ----- サーバー -----
PORT=5000
NODE_ENV=development

# ----- Telegram Bot (本番では必須) -----
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-from-botfather

# ----- Python (libral-core) 連携（任意） -----
LIBRAL_PYTHON_URL=http://localhost:8000
LIBRAL_PYTHON_TIMEOUT_MS=5000
# 本番で infer_local を内部のみに制限する場合、Node と Python で同じ値を設定
# LIBRAL_INTERNAL_SECRET=your-shared-secret

# ----- 開発時のみ（任意） -----
# VITE_HMR_PORT=5174

# ----- DB / Redis（任意・本番推奨） -----
# DATABASE_URL=postgresql://user:pass@localhost:5432/libral_node
# REDIS_URL=redis://localhost:6379
