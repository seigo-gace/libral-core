###############################################
# Libral Core - 本番高速運用用 .env テンプレート
# 目的: 起動速度と安定性を最優先にした最小構成
###############################################

########## Node.js (Fastify) ##########

# HTTP サーバーポート（必要に応じて変更）
PORT=5000

# 本番モード（ログ最小化・Vite 無効）
NODE_ENV=production

########## Telegram Bot ##########

# 本番で Telegram Bot を使う場合は必須
# 未設定でもサーバー自体は起動する（モック動作）
TELEGRAM_BOT_TOKEN=change-me-real-token

########## Python (libral-core) 連携 ##########

# Python サービスを使わない場合はコメントアウトのままで OK
# 使う場合のみ有効化して、URL を合わせる
#LIBRAL_PYTHON_URL=http://localhost:8000

# Python 健全性チェックのタイムアウト（高速フェイル用）
LIBRAL_PYTHON_TIMEOUT_MS=2000

########## DB / Redis ##########

# 高速・シンプル運用では Neon/PostgreSQL は完全オプション
# DATABASE_URL を設定しなければ、Node 側は DB に一切接続しない
#DATABASE_URL=postgresql://user:pass@localhost:5432/libral_node

# Redis を使わない場合は未設定で OK（インメモリモック）
# 本番でキュー／キャッシュを使いたいときだけ設定する
#REDIS_URL=redis://localhost:6379

########## Aegis-PGP / GPG ##########

# AEGIS_URL を設定すると、server/crypto/aegisClient.ts から
# GPG バックエンドの Aegis-PGP サービスを利用できます。
# 未設定時は開発用モッククライアントで動作します。
AEGIS_URL=https://aegis-pgp.example.com

